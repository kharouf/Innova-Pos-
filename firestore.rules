rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && (
               request.auth.token.email == "kharoufwala24@gmail.com" || 
               request.auth.token.email == "walakharouf665@gmail.com" || 
               request.auth.token.email == "walakharouf6665@gmail.com"
             );
    }

    // Tenant Isolation match rule helper
    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Ensure document IDs aren't poisoned with overflow contents (PII or injections)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // System Updates
    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tenant Isolation match rule
    match /users/{userId} {
      // Allows user's single metadata or config read/write
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow write: if isOwner(userId);

      // Secure subcollections
      match /products/{productId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /partners/{partnerId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /invoices/{invoiceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /payments/{paymentId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /traites/{traiteId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /expenses/{expenseId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /superettes_meta/{superetteId} {
        allow get, write: if isOwner(userId);
        allow list: if isOwner(userId);
      }

      match /superettes/{superetteId} {
        allow get, write: if isOwner(userId);
        allow list: if isOwner(userId);

        match /products/{productId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
        
        match /partners/{partnerId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
        
        match /invoices/{invoiceId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
        
        match /payments/{paymentId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
        
        match /traites/{traiteId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
        
        match /expenses/{expenseId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow write: if isOwner(userId);
        }
      }
    }
  }
}
